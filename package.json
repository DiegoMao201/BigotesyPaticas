{
  "name": "bigotesypaticas",
  "version": "0.1.0",
  "private": true,
  "description": "Plataforma empresarial Bigotes y Paticas — monorepo",
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=20.10.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "type-check": "turbo run type-check",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,mdx,css,html}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,mdx,css,html}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "turbo": "^2.2.3",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "typescript": "^5.6.3"
  }
}
