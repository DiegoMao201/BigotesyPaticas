# =============================================================================
# .env.production.example — PRODUCCIÓN (Coolify)
# NUNCA commitear el archivo real. Cargar valores en Coolify UI por servicio.
#
# ⚠️  AVISO: El 2026-05-10 se detectó pegado de secretos reales en este
# archivo .example. Se movieron a `project-secrets/.env.production`
# (gitignored) y se RECOMIENDA ROTAR todas las credenciales que estuvieron
# expuestas en el portapapeles/editor (ver MISSING_SECRETS.md sección
# "Incidente de exposición local 2026-05-10").
# =============================================================================

APP_ENV=production
LOG_LEVEL=INFO
APP_BASE_URL=https://api.datovatenexuspro.com

# ---------------------------------------------------------------------------
# Postgres (Coolify-managed)  — usar instancia ya provisionada en NYC1
# ---------------------------------------------------------------------------
POSTGRES_HOST=PUT_VALUE_HERE
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=PUT_VALUE_HERE
DATABASE_URL=postgres://postgres:PUT_VALUE_HERE@PUT_HOST:5432/postgres

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_URL=redis://PUT_HOST:6379/0

# ---------------------------------------------------------------------------
# Object storage — DigitalOcean Spaces (existente) o MinIO
# ---------------------------------------------------------------------------
SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
SPACES_REGION=nyc3
SPACES_BUCKET=PUT_VALUE_HERE
SPACES_KEY=PUT_VALUE_HERE
SPACES_SECRET=PUT_VALUE_HERE
SPACES_PUBLIC_URL=PUT_VALUE_HERE

# Compat S3 (alias por si algún servicio espera nombres S3_*)
S3_ENDPOINT=${SPACES_ENDPOINT}
S3_REGION=${SPACES_REGION}
S3_BUCKET=${SPACES_BUCKET}
S3_ACCESS_KEY=${SPACES_KEY}
S3_SECRET_KEY=${SPACES_SECRET}

# ---------------------------------------------------------------------------
# Auth
# ---------------------------------------------------------------------------
JWT_SECRET=PUT_VALUE_HERE                 # min 32 bytes random, ROTAR cuatrimestralmente
AUTH_SECRET=PUT_VALUE_HERE                # NextAuth (frontend)
AUTH_URL=https://panel.datovatenexuspro.com
SESSION_COOKIE_DOMAIN=.datovatenexuspro.com
SESSION_COOKIE_SECURE=true

# ---------------------------------------------------------------------------
# Frontend
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=https://api.datovatenexuspro.com/api/v1
NEXT_PUBLIC_STORE_URL=https://tienda.datovatenexuspro.com
NEXT_PUBLIC_ADMIN_URL=https://panel.datovatenexuspro.com

# ---------------------------------------------------------------------------
# Google Sheets (legacy + ETL)
# ---------------------------------------------------------------------------
SHEET_URL=PUT_VALUE_HERE
GOOGLE_SERVICE_ACCOUNT_JSON=PUT_VALUE_HERE_SINGLE_LINE_JSON
GOOGLE_SERVICE_ACCOUNT_RO_JSON=PUT_VALUE_HERE_READ_ONLY_FOR_ETL

# ---------------------------------------------------------------------------
# Email (SMTP)
# ---------------------------------------------------------------------------
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_SENDER_EMAIL=PUT_VALUE_HERE
SMTP_SENDER_PASSWORD=PUT_VALUE_HERE       # App Password de Gmail

# ---------------------------------------------------------------------------
# Integraciones
# ---------------------------------------------------------------------------
WHATSAPP_API_TOKEN=PUT_VALUE_HERE
WHATSAPP_PHONE_NUMBER_ID=PUT_VALUE_HERE
PAYMENTS_PROVIDER=                         # wompi | mercadopago | stripe (vacío = mock)
PAYMENTS_API_KEY=PUT_VALUE_HERE
PAYMENTS_API_SECRET=PUT_VALUE_HERE
PAYMENTS_WEBHOOK_SECRET=PUT_VALUE_HERE

# IA / LLM (opcional — usado por workers de enriquecimiento)
OPENROUTER_API_KEY=PUT_VALUE_HERE
OPENROUTER_MODEL=google/gemini-flash-1.5

# ---------------------------------------------------------------------------
# Observabilidad
# ---------------------------------------------------------------------------
SENTRY_DSN=PUT_VALUE_HERE
OTEL_EXPORTER_OTLP_ENDPOINT=PUT_VALUE_HERE
PROMETHEUS_ENABLED=true

# ---------------------------------------------------------------------------
# Feature flags (cutover por módulo, controladas también en DB)
# ---------------------------------------------------------------------------
FF_USE_PG_CATALOG_READ=false
FF_USE_PG_CATALOG_WRITE=false
FF_USE_PG_POS=false
FF_DUAL_WRITE_SHEETS=true
