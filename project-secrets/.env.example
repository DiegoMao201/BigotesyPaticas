# =============================================================================
# .env.example — plantilla GENÉRICA para todos los entornos
# Copiar a `.env` (NO COMMIT) y completar valores reales.
# =============================================================================

# ----- Streamlit legacy (app actual) ---------------------------------------
# Estas variables hoy viven en `st.secrets` en Streamlit Cloud.
# Replicarlas aquí permite levantar la app localmente sin Streamlit Cloud.
SHEET_URL=PUT_VALUE_HERE                 # URL completa del Google Spreadsheet maestro
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=PUT_PATH_HERE  # Ruta absoluta al JSON del service account
# Alternativa: contenido inline (escapar comillas) — preferir el path
# GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'

# ----- Nueva plataforma (FastAPI + Postgres + Redis) -----------------------
APP_ENV=development                       # development | staging | production
APP_NAME=bigotesypaticas
APP_TIMEZONE=America/Bogota
APP_BASE_URL=http://localhost:8000
LOG_LEVEL=INFO

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=bigotesypaticas
POSTGRES_USER=app_rw
POSTGRES_PASSWORD=PUT_VALUE_HERE
DATABASE_URL=postgresql+psycopg://app_rw:PUT_VALUE_HERE@localhost:5432/bigotesypaticas

# Redis
REDIS_URL=redis://localhost:6379/0

# Object storage (MinIO/S3)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=bigotesypaticas
S3_ACCESS_KEY=PUT_VALUE_HERE
S3_SECRET_KEY=PUT_VALUE_HERE

# JWT / Auth
JWT_SECRET=PUT_VALUE_HERE                 # min 32 bytes random
JWT_ALG=HS256
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800
SESSION_COOKIE_DOMAIN=localhost
SESSION_COOKIE_SECURE=false               # true en prod

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_STORE_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001

# Integraciones
WHATSAPP_API_TOKEN=PUT_VALUE_HERE          # WhatsApp Cloud API (no usado todavía)
WHATSAPP_PHONE_NUMBER_ID=PUT_VALUE_HERE
PAYMENTS_PROVIDER=                         # wompi | mercadopago | stripe (vacío = desactivado)
PAYMENTS_API_KEY=PUT_VALUE_HERE
PAYMENTS_API_SECRET=PUT_VALUE_HERE
PAYMENTS_WEBHOOK_SECRET=PUT_VALUE_HERE

# Observabilidad
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
PROMETHEUS_ENABLED=true

# Feature flags (defaults)
FF_USE_PG_CATALOG_READ=false
FF_USE_PG_CATALOG_WRITE=false
FF_USE_PG_POS=false
FF_DUAL_WRITE_SHEETS=true
