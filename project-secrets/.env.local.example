# =============================================================================
# .env.local.example — DESARROLLO LOCAL
# Copiar a `.env.local` (NO COMMIT). Sobrescribe a `.env`.
# =============================================================================

APP_ENV=development
LOG_LEVEL=DEBUG

# Postgres local (docker-compose)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=bigotesypaticas_dev
POSTGRES_USER=app_rw
POSTGRES_PASSWORD=devpass
DATABASE_URL=postgresql+psycopg://app_rw:devpass@localhost:5432/bigotesypaticas_dev

REDIS_URL=redis://localhost:6379/0

# MinIO local
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=bigotesypaticas-dev
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# Auth dev (NO usar en prod)
JWT_SECRET=dev-only-change-me-32-bytes-min-xxxxxxxxxxxxxxxxxx
SESSION_COOKIE_SECURE=false

# Frontend dev
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_STORE_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001

# Sheets dev (apuntar a un spreadsheet de pruebas, NUNCA al de prod)
SHEET_URL=PUT_DEV_SHEET_URL_HERE
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=./project-secrets/google-service-account-dev.json

# Flags (todo desactivado por defecto en dev)
FF_USE_PG_CATALOG_READ=false
FF_USE_PG_CATALOG_WRITE=false
FF_USE_PG_POS=false
FF_DUAL_WRITE_SHEETS=true
