# =============================================================================
# Bigotes y Paticas API — variables de entorno
# Copiar a .env y ajustar.
# =============================================================================

ENVIRONMENT=local
LOG_LEVEL=INFO
APP_NAME=BigotesyPaticas API
APP_VERSION=0.1.0

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3100

# Database
DATABASE_URL=postgresql+asyncpg://postgres:devpass@localhost:5432/bp_dev
# Para Alembic (driver síncrono)
DATABASE_URL_SYNC=postgresql+psycopg://postgres:devpass@localhost:5432/bp_dev

# Pool
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=dev-only-change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=14

# Bootstrap admin (se crea si no existe en la primera migración seed)
ADMIN_EMAIL=admin@bigotesypaticas.com
ADMIN_PASSWORD=ChangeMe!2026

# Object storage (S3-compatible: MinIO local / DO Spaces prod)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_UPLOADS=bp-uploads
S3_BUCKET_PUBLIC=bp-public
S3_PUBLIC_URL=http://localhost:9000

# Sheets ETL (lectura del legacy)
SHEET_URL=
GOOGLE_SERVICE_ACCOUNT_JSON=

# Feature flags (override de defaults en bp_common.flags)
FF_DUAL_WRITE_SHEETS=true
FF_USE_PG_POS=false
